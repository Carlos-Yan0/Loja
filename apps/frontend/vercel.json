{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://loja-zrjg.onrender.com/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://loja-zrjg.onrender.com/uploads/$1"
    },
    { "source": "/((?!.*\\..*).*)", "destination": "/index.html" }
  ]
}
